diff --git a/rc/tmux.conf b/rc/tmux.conf
new file mode 100644
index 0000000..79dbb0f
--- /dev/null
+++ b/rc/tmux.conf
@@ -0,0 +1,140 @@
+# =============================================================================
+# ~/.tmux.conf — Zellij-like tmux configuration
+# Managed via ~/Projects/github/dots/rc/tmux.conf (symlinked by rake link)
+# =============================================================================
+
+# TERMINAL & COLORS
+set -g default-terminal "tmux-256color"
+set -as terminal-features ",xterm-256color:clipboard"
+
+# HISTORY (preserve existing 100000; overrides tmux-sensible's lower 50000)
+set -g history-limit 100000
+
+# PREFIX — Ctrl+/  (sends ASCII 31 / C-_ in most terminals)
+# If prefix doesn't respond: change C-/ to C-_ here
+unbind C-b
+set -g prefix 'C-_'
+bind 'C-_' send-prefix
+
+# MOUSE — mirrors Zellij mouse_mode true
+set -g mouse on
+
+# WINDOW & PANE NUMBERING
+set -g base-index 1
+setw -g pane-base-index 1
+set -g renumber-windows on
+
+# PANE BORDERS — visual frames like Zellij pane_frames
+set -g pane-border-style "fg=#45475a"
+set -g pane-active-border-style "fg=#89b4fa"
+set -g pane-border-status top
+set -g pane-border-format " #{pane_index}: #{pane_title} "
+
+# STATUS BAR — bottom bar with keybinding hints (like Zellij's hint bar)
+set -g status on
+set -g status-position bottom
+set -g status-interval 5
+set -g status-justify left
+set -g status-style "bg=#1e1e2e,fg=#cdd6f4"
+set -g status-left-length 40
+set -g status-left "#[bg=#89b4fa,fg=#1e1e2e,bold] #S #[bg=#1e1e2e,fg=#89b4fa]"
+setw -g window-status-format " #I:#W "
+setw -g window-status-style "fg=#6c7086,bg=#1e1e2e"
+setw -g window-status-current-format "#[bg=#313244,fg=#89b4fa,bold] #I:#W#{?window_zoomed_flag, [Z],} #[bg=#1e1e2e,fg=#313244]"
+set -g status-right-length 120
+set -g status-right "#[fg=#a6e3a1] Ctrl+_+n split-v  Ctrl+_+p split-h  Ctrl+_+z zoom  Alt+Arrow nav #[fg=#45475a]│#[fg=#6c7086] %Y-%m-%d %H:%M "
+
+# COPY MODE — vi-style (like Zellij scroll mode)
+setw -g mode-keys vi
+set -g mode-style "bg=#313244,fg=#cdd6f4"
+bind PageUp copy-mode -u
+bind -n WheelUpPane if-shell -F "#{mouse_any_flag}" "send-keys -M" \
+    "if -Ft= '#{pane_in_mode}' 'send-keys -M' 'copy-mode -e; send-keys -M'"
+bind -T copy-mode-vi v send-keys -X begin-selection
+bind -T copy-mode-vi y send-keys -X copy-selection-and-cancel
+bind -T copy-mode-vi r send-keys -X rectangle-toggle
+bind -T copy-mode-vi Escape send-keys -X cancel
+bind -T copy-mode-vi / command-prompt -p "search down:" "send-keys -X search-forward '%%'"
+bind -T copy-mode-vi ? command-prompt -p "search up:" "send-keys -X search-backward '%%'"
+
+# PANE SPLITTING
+bind n split-window -h -c "#{pane_current_path}"   # n = new vertical (right)
+bind p split-window -v -c "#{pane_current_path}"   # p = new horizontal (below)
+bind | split-window -h -c "#{pane_current_path}"   # | alias
+bind - split-window -v -c "#{pane_current_path}"   # - alias
+unbind '"'
+unbind %
+bind c new-window -c "#{pane_current_path}"
+
+# PANE NAVIGATION — Alt+Arrow without prefix (matches Zellij Alt+arrow)
+bind -n M-Left  select-pane -L
+bind -n M-Right select-pane -R
+bind -n M-Up    select-pane -U
+bind -n M-Down  select-pane -D
+bind h select-pane -L
+bind j select-pane -D
+bind k select-pane -U
+bind l select-pane -R
+
+# PANE RESIZING — Alt+Shift+Arrow (like Zellij resize mode)
+bind -n M-S-Left  resize-pane -L 3
+bind -n M-S-Right resize-pane -R 3
+bind -n M-S-Up    resize-pane -U 3
+bind -n M-S-Down  resize-pane -D 3
+bind Left  resize-pane -L 1
+bind Right resize-pane -R 1
+bind Up    resize-pane -U 1
+bind Down  resize-pane -D 1
+
+# WINDOW NAVIGATION — direct number jump (n/p rebound to splits above)
+bind 1 select-window -t :1
+bind 2 select-window -t :2
+bind 3 select-window -t :3
+bind 4 select-window -t :4
+bind 5 select-window -t :5
+
+# ZOOM — like Zellij pane mode z (ToggleFocusFullscreen)
+bind z resize-pane -Z
+
+# MISC
+set -g escape-time 0
+set -g focus-events on
+set -sg repeat-time 500
+set -g display-time 3000
+set -g visual-activity off
+set -g bell-action none
+bind r source-file ~/.tmux.conf \; display-message "Config reloaded!"
+
+# TPM PLUGIN MANAGER PATH — point to dotfiles submodules (not ~/.tmux/plugins)
+set-environment -g TMUX_PLUGIN_MANAGER_PATH "$HOME/Projects/github/dots/tmux/plugins/"
+
+# PLUGINS (kept for TPM's prefix+U update mechanism; cloning skipped since dirs exist)
+set -g @plugin 'tmux-plugins/tpm'
+set -g @plugin 'tmux-plugins/tmux-sensible'
+set -g @plugin 'tmux-plugins/tmux-resurrect'
+set -g @plugin 'tmux-plugins/tmux-continuum'
+set -g @plugin 'tmux-plugins/tmux-yank'
+set -g @plugin 'sainnhe/tmux-fzf'
+set -g @plugin 'catppuccin/tmux'
+
+# tmux-resurrect: save/restore pane contents (like Zellij session serialization)
+set -g @resurrect-capture-pane-contents 'on'
+set -g @resurrect-processes 'vim nvim ssh man less'
+set -g @resurrect-dir '~/.tmux/resurrect'
+
+# tmux-continuum: auto-save every 15 min (like Zellij serialization_interval)
+set -g @continuum-restore 'on'
+set -g @continuum-save-interval '15'
+
+# tmux-fzf: Ctrl+/ then F — fuzzy search panes/windows/sessions
+TMUX_FZF_LAUNCH_KEY="F"
+set -g @tmux-fzf-preview '1'
+
+# catppuccin: polished status bar (overrides manual status-* settings above if loaded)
+set -g @catppuccin_flavor 'mocha'
+set -g @catppuccin_window_status_style "rounded"
+set -g @catppuccin_status_modules_right "session date_time"
+set -g @catppuccin_date_time_text "%Y-%m-%d %H:%M"
+
+# MUST BE LAST LINE — run TPM from dotfiles submodule
+run '$HOME/Projects/github/dots/tmux/plugins/tpm/tpm'
